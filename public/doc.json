{
    "openapi": "3.0.0",
    "info": {
        "title": "Loan Application API",
        "description": "API for managing loan clients and loan applications.",
        "version": "1.0.0"
    },
    "paths": {
        "/applications": {
            "get": {
                "operationId": "get_get_applications",
                "responses": {
                    "default": {
                        "description": ""
                    }
                }
            },
            "post": {
                "operationId": "post_create_application",
                "responses": {
                    "default": {
                        "description": ""
                    }
                }
            }
        },
        "/applications/{id}": {
            "get": {
                "operationId": "get_get_one_application",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "default": {
                        "description": ""
                    }
                }
            },
            "delete": {
                "operationId": "delete_delete_application",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "default": {
                        "description": ""
                    }
                }
            },
            "patch": {
                "operationId": "patch_update_application",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "default": {
                        "description": ""
                    }
                }
            }
        },
        "/clients": {
            "get": {
                "summary": "Get paginated list of clients",
                "operationId": "get_get_clients",
                "parameters": [
                    {
                        "name": "page",
                        "in": "query",
                        "description": "Page number",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "example": 1,
                            "default": 1,
                            "minimum": 1
                        }
                    },
                    {
                        "name": "limit",
                        "in": "query",
                        "description": "Number of items per page",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "example": 10,
                            "default": 10,
                            "maximum": 100,
                            "minimum": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "List of clients"
                    }
                }
            },
            "post": {
                "summary": "Create client",
                "operationId": "post_create_client",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "firstName",
                                    "lastName",
                                    "email",
                                    "phoneNumber"
                                ],
                                "properties": {
                                    "firstName": {
                                        "type": "string",
                                        "example": "John"
                                    },
                                    "lastName": {
                                        "type": "string",
                                        "example": "Doe"
                                    },
                                    "email": {
                                        "type": "string",
                                        "example": "john.doe@mail.com"
                                    },
                                    "phoneNumber": {
                                        "type": "string",
                                        "example": "+37101234567"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Client created"
                    },
                    "400": {
                        "description": "Invalid JSON"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
        "/clients/{id}": {
            "get": {
                "summary": "Get client by ID",
                "operationId": "get_get_one_client",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "Client ID",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Client found"
                    },
                    "404": {
                        "description": "Client not found"
                    }
                }
            },
            "delete": {
                "summary": "Delete client",
                "operationId": "delete_delete_client",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "Client ID",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Client deleted"
                    },
                    "404": {
                        "description": "Client not found"
                    }
                }
            },
            "patch": {
                "summary": "Update client",
                "operationId": "patch_update_client",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "Client ID",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 1
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "firstName": {
                                        "type": "string",
                                        "example": "Jane"
                                    },
                                    "lastName": {
                                        "type": "string",
                                        "example": "Doe"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "jane.doe@mail.com"
                                    },
                                    "phoneNumber": {
                                        "type": "string",
                                        "example": "+37101234568"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Client updated"
                    },
                    "400": {
                        "description": "Invalid JSON or unwritable fields"
                    },
                    "404": {
                        "description": "Client not found"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        }
    }
}
